function calcType(answers){
  var c={hitoniku:0,kanpeki:0,jikohitei:0,yokuatsu:0,jibun:0};
  answers.forEach(function(ty){if(c[ty]!==undefined)c[ty]++;});
  if(c.jibun>=6)return 'jibun';
  var best='hitoniku';var bv=0;
  ['hitoniku','kanpeki','jikohitei','yokuatsu'].forEach(function(k){if(c[k]>bv){bv=c[k];best=k;}});
  return best;
}

