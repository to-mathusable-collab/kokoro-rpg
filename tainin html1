function calcTypeFinal(answers){var c={hitoniku:0,kanpeki:0,jikohitei:0,yokuatsu:0,jibun:0};answers.forEach(function(ty){if(c[ty]!==undefined)c[ty]++;});if(c.jibun>=6)return 'jibun';var best='hitoniku';var bv=0;['hitoniku','kanpeki','jikohitei','yokuatsu'].forEach(function(k){if(c[k]>bv){bv=c[k];best=k;}});return best;}
function glv(n){return LV[Math.min(Math.max(n,1),7)-1];}
function byName(name){return IT.find(function(i){return i.name===name;})||IT[0];}
function xpProg(lv,xp){var f=XPR[lv-1]||0;var t=XPR[lv]||null;var c=xp-f;var nd=t?t-f:null;return{c:c,nd:nd,p:nd?Math.min(100,(c/nd)*100):100};}
function s2lv(sc){var a=sc.reduce(function(x,y){return x+y;},0)/sc.length;if(a<1.7)return 1;if(a<2.8)return 2;if(a<4.1)return 3;if(a<5.1)return 4;if(a<5.9)return 5;if(a<6.5)return 6;return 7;}
function getQS(ut){return QS[ut]||QS.hitoniku;}
function getEnemy(ut,level){if(ut&&TYPE_ENEMIES[ut]){var id=TYPE_ENEMIES[ut][Math.min(level-1,6)];return EN.find(function(x){return x.id===id;})||EN[0];}return EN[0];}
function getChar(id){return CHARS[id]||CHARS.ukeireru||CHARS.yudaneru;}

