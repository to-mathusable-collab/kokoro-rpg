function INIT(){try{var s=localStorage.getItem('kokoro_tainin2');if(s)return JSON.parse(s);}catch(e){}return{level:1,xp:0,anxiety:70,selfAxis:30,energy:45,equippedItems:['emotion_note','life_mantle'],actions:[],reflections:[],userType:null};}
function reducer(s,a){
  if(a.t==='XP'){var nx=s.xp+a.v;var nl=s.level;while(nl<7&&nx>=XPR[nl])nl++;return Object.assign({},s,{xp:nx,level:nl});}
  if(a.t==='CHECK')return Object.assign({},s,a.p);
  if(a.t==='ACT')return Object.assign({},s,{actions:[a.a].concat(s.actions).slice(0,60)});
  if(a.t==='REF')return Object.assign({},s,{reflections:[a.r].concat(s.reflections).slice(0,30)});
  if(a.t==='EQ'){var eq=s.equippedItems.includes(a.id)?s.equippedItems.filter(function(x){return x!==a.id;}):[].concat(s.equippedItems,[a.id]);return Object.assign({},s,{equippedItems:eq});}
  if(a.t==='SET_TYPE')return Object.assign({},s,{userType:a.ty,level:1,xp:0,anxiety:70,selfAxis:30,energy:45});
  return s;
}

