function App(){
  var stateArr=useReducer(reducer,null,INIT);
  var state=stateArr[0];var dispatch=stateArr[1];
  var screen=useState('welcome');var setScreen=screen[1];screen=screen[0];
  var hist=useState([]);var setHist=hist[1];hist=hist[0];
  useEffect(function(){try{localStorage.setItem('kokoro_tainin2',JSON.stringify(state));}catch(e){};},[state]);
  function nav(to){setHist(hist.concat([screen]));setScreen(to);document.getElementById('root').scrollTop=0;}
  function goBack(){if(hist.length){var p=hist[hist.length-1];setHist(hist.slice(0,-1));setScreen(p);}else setScreen('home');document.getElementById('root').scrollTop=0;}
  var screens={
    welcome:Welcome,
    home:Home,
    type_diagnosis:TypeDiagnosis,
    type_result:TypeResult,
    check:Check,
    result:Result,
    level_result:LevelResult,
    premium:Premium,
    chat:Chat,
    actions:Actions,
    reflect:Reflect,
    equip:Equip,
    guide:Guide,
    monsters:Monsters,
    characters:Characters,
    psychology:Psychology,
    notice:Notice
  };
  var Screen=screens[screen]||Welcome;
  return h(Ctx.Provider,{value:{state:state,dispatch:dispatch,nav:nav,goBack:goBack}},h(Screen,null));
}
ReactDOM.render(h(App,null),document.getElementById('root'));
